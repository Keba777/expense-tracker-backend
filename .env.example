APP_ENV=development
APP_PORT=8080
APP_NAME=ExpenseTracker

DB_HOST=localhost
DB_PORT=5432
DB_USER=expense_user
DB_PASSWORD=expense_pass
DB_NAME=expense_tracker
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=300

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass
REDIS_DB=0

JWT_ACCESS_SECRET=change_me_access_secret_32chars_min
JWT_REFRESH_SECRET=change_me_refresh_secret_32chars_min
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=30

# Local dev: specific origin. Hosted: set to * to allow any frontend, or comma-separate multiple URLs
CORS_ORIGINS=http://localhost:3000
# CORS_ORIGINS=*
# CORS_ORIGINS=https://your-app.vercel.app,https://your-app.railway.app

RATE_LIMIT_MAX=100
RATE_LIMIT_EXPIRY_SECONDS=60
